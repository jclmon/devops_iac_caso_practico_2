[all:vars]  
ansible_ssh_private_key_file=./../ansible/keys/id_rsa
ansible_host_key_checking=False

[local]
localhost ansible_connection=local

[local:vars]
ansible_connection=local

[azure_vms]
VM_NAME ansible_host=XXX.XXX.XX.XX

[azure_vms:vars]
ansible_user=azureuser
ansible_ssh_private_key_file=./../ansible/keys/id_rsa
ansible_python_interpreter=/usr/bin/python3
acr_login_server=YOUR_ACR_NAME.azurecr.io
acr_username=YOUR_ACR_USERNAME
acr_password=YOUR_ACR_PASSWORD
container_image=YOUR_ACR_NAME.azurecr.io/azure-vote-front:latest

[acr]
acr_server ansible_host=YOUR_ACR_NAME.azurecr.io

[acr:vars]
ansible_connection=local
acr_name=YOUR_ACR_NAME
acr_login_server=YOUR_ACR_NAME.azurecr.io
acr_username=YOUR_ACR_USERNAME
acr_password=YOUR_ACR_PASSWORD

[aks]
aks_cluster ansible_host=YOUR_AKS_CLUSTER_NAME

[aks:vars]
ansible_connection=local
resource_group_name=YOUR_RESOURCE_GROUP_NAME
aks_cluster_name=YOUR_AKS_CLUSTER_NAME
aks_cluster_id=/subscriptions/YOUR_SUBSCRIPTION_ID/resourceGroups/YOUR_RESOURCE_GROUP_NAME/providers/Microsoft.ContainerService/managedClusters/YOUR_AKS_CLUSTER_NAME
acr_login_server=YOUR_ACR_NAME.azurecr.io
acr_username=YOUR_ACR_USERNAME
acr_password=YOUR_ACR_PASSWORD
container_image=YOUR_ACR_NAME.azurecr.io/azure-vote-front:latest
redis_image=YOUR_ACR_NAME.azurecr.io/redis:latest
